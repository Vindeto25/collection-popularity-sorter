    "@types/react-dom": "^18.3.7",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
